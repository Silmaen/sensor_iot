# OTA publication credentials — copy to tools/ota.env (gitignored) and fill in.
# Auto-loaded by tools/publish_firmware.py; real environment variables and
# command-line flags take precedence over values set here.

# Base URL of the publication API (no trailing slash). Use https:// if the
# server sits behind a TLS-terminating reverse proxy (e.g. nginx 301 http->https).
OTA_API_URL=https://sensor.example.net

# Publication bearer token (server settings.OTA_PUBLISH_TOKEN). CI credential —
# distinct from the read-only API key. Keep it out of git.
OTA_PUBLISH_TOKEN=change-me
